{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spectrum",
  "version": "0.1.0",
  "identifier": "com.observatory.spectrum",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Spectrum — news watcher",
        "width": 1100,
        "height": 780,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#06080f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
